# Garden Quest - staging example
# Copy to .env.staging or pass it to deploy via ENV_FILE / -EnvFile.
# You can deploy in two modes:
# 1. Inline secrets in this file
# 2. Google Secret Manager references via *_SECRET_NAME / *_SECRET_VERSION
# Use only one mode per secret.

APP_ENV=staging
NODE_ENV=production

# Google OAuth
GOOGLE_CLIENT_ID=your-staging-google-client-id.apps.googleusercontent.com
# Option A: fill GOOGLE_CLIENT_SECRET inline and leave GOOGLE_CLIENT_SECRET_SECRET_NAME empty.
# Option B: leave GOOGLE_CLIENT_SECRET inline empty and fill GOOGLE_CLIENT_SECRET_SECRET_NAME below.
GOOGLE_CLIENT_SECRET=replace-with-your-staging-google-client-secret
GOOGLE_REDIRECT_URI=https://staging.example.com/auth/callback

# Frontend
FRONTEND_URL=https://staging.example.com
LOCAL_BACKEND_URL=http://localhost:8080

# Security
# Option A: fill JWT_SECRET inline and leave JWT_SECRET_SECRET_NAME empty.
# Option B: leave JWT_SECRET inline empty and fill JWT_SECRET_SECRET_NAME below.
JWT_SECRET=replace-with-a-long-random-staging-secret
ADMIN_GOOGLE_EMAILS=admin@example.com
COOKIE_SECURE=true
COOKIE_SAME_SITE=Lax
COOKIE_DOMAIN=
SESSION_COOKIE_MAX_AGE_MS=86400000
SESSION_TOUCH_INTERVAL_MS=300000

# Database
# Option A: fill SUPABASE_DB_URL inline and leave SUPABASE_DB_URL_SECRET_NAME empty.
# Option B: leave SUPABASE_DB_URL inline empty and fill SUPABASE_DB_URL_SECRET_NAME below.
# Use the exact connection string from the Supabase "Connect" panel.
# For a persistent backend on Cloud Run, prefer the Session pooler when using IPv4.
SUPABASE_DB_URL=postgresql://<db-user>:<db-password>@<db-host>:<db-port>/postgres
SUPABASE_DB_SSL=true
SUPABASE_DB_SSL_CA_PATH=

# Optional AI
# Option A: fill OPENAI_API_KEY inline and leave OPENAI_API_KEY_SECRET_NAME empty.
# Option B: leave OPENAI_API_KEY inline empty and fill OPENAI_API_KEY_SECRET_NAME below.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-nano
OPENAI_API_TIMEOUT_MS=10000
OPENAI_PROJECT_ID=
OPENAI_ORGANIZATION_ID=

# Secret Manager references used by deploy
# Leave these empty if you prefer inline secrets above.
OPENAI_API_KEY_SECRET_NAME=gardenquest-openai-api-key
OPENAI_API_KEY_SECRET_VERSION=1
JWT_SECRET_SECRET_NAME=gardenquest-jwt-secret
JWT_SECRET_SECRET_VERSION=1
SUPABASE_DB_URL_SECRET_NAME=gardenquest-supabase-db-url
SUPABASE_DB_URL_SECRET_VERSION=1
GOOGLE_CLIENT_SECRET_SECRET_NAME=gardenquest-google-client-secret
GOOGLE_CLIENT_SECRET_SECRET_VERSION=1

# AI Player
AI_GAME_ENABLED=true
AI_AGENT_NAME=Jardineiro IA
AI_DECISION_INTERVAL_MS=4000
AI_SIMULATION_TICK_MS=250
AI_MOVE_SPEED=3.5
AI_SPEECH_MAX_CHARS=80
OPENAI_REASONING_EFFORT=low
PLAYER_MOVE_SPEED=8
PLAYER_RUN_SPEED=12.5
PLAYER_CHAT_MAX_CHARS=72
PLAYER_CHAT_BLOCKED_WORDS=merda,porra,caralho,pqp,fdp,otario
PLAYER_IDLE_TIMEOUT_MS=20000

# World Runtime (API + Worker split)
AGENT_WORLD_ENABLED=true
AGENT_WORLD_SYNC_MS=30000
AGENT_WORLD_DECISION_INTERVAL_MS=4000
AGENT_WORLD_MAX_ACTIVE=16
AGENT_WORLD_CONCURRENT_DECISIONS=2
AGENT_MOVE_SPEED=3.4
REALM_ID=gardenquest-world-01
AGENT_WORLD_REQUIRE_LEASE=false
REALM_LEASE_TTL_MS=20000
WORLD_COMMAND_POLL_MS=500
WORLD_SNAPSHOT_FLUSH_MS=1000
WORLD_COMMAND_BATCH_SIZE=50
WORLD_RUNTIME_SNAPSHOT_TTL_MS=15000
WORLD_COMMAND_MAX_ATTEMPTS=5
WORLD_COMMAND_RETRY_BASE_MS=1200

# Realtime / Event Feed
WORLD_EVENT_STREAM_ENABLED=true
WORLD_EVENT_STREAM_POLL_MS=500
WORLD_EVENT_STREAM_HEARTBEAT_MS=15000
WORLD_EVENT_STREAM_TOUCH_MS=10000
WORLD_EVENT_STREAM_SNAPSHOT_EVERY=1
WORLD_EVENT_STREAM_FALLBACK_POLL_MS=5000
WORLD_RUNTIME_BUS_ENABLED=true
WORLD_RUNTIME_BUS_RECONNECT_MS=2000

# Agent Moderation / Governance / Quarantine
AGENT_DEFAULT_DAILY_RUN_BUDGET=5000
AGENT_DEFAULT_MIN_DECISION_INTERVAL_MS=2000
AGENT_CIRCUIT_FAILURE_THRESHOLD=5
AGENT_CIRCUIT_COOLDOWN_MS=30000
AGENT_PROVIDER_CIRCUIT_FAILURE_THRESHOLD=10
AGENT_PROVIDER_CIRCUIT_COOLDOWN_MS=60000
AGENT_SPEECH_MODERATION_ENABLED=true
AGENT_SPEECH_ALLOW_URLS=false
AGENT_SPEECH_BLOCKLIST=discord.gg,t.me/,http://,https://
AGENT_ENDPOINT_QUARANTINE_FAILURE_THRESHOLD=6
AGENT_ENDPOINT_QUARANTINE_SUSPICIOUS_THRESHOLD=2
AGENT_ENDPOINT_QUARANTINE_MS=900000

# Cloud Run
PROJECT_ID=your-gcp-project-id
REGION=southamerica-east1
BACKEND_SERVICE_NAME=gardenquest-api-staging
FRONTEND_SERVICE_NAME=gardenquest-web-staging
